{
  "name": "3d-personal-homepage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:open": "vite --open",
    "dev:service": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "frontend:public:build": "npm --prefix blueprint3d-babylon run build",
    "frontend:public:serve": "node .\\scripts\\Serve-BlueprintStatic.mjs",
    "frontend:check": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Check-FrpFrontend.ps1",
    "frontend:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Restart-FrpFrontend.ps1",
    "frontend:ensure": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Ensure-Frontend.ps1",
    "frontend:register-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Register-FrontendWatchdogTask.ps1"
  },
  "dependencies": {
    "@babylonjs/core": "^7.11.0",
    "@babylonjs/gui": "^7.11.0",
    "nipplejs": "^1.0.4"
  },
  "devDependencies": {
    "lucide-static": "^1.18.0",
    "vite": "^5.0.0"
  }
}
